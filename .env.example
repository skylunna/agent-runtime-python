# 应用
APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# 数据库 (psycopg 用的 DSN 格式)
PG_DSN=postgresql://rag:rag123@your-server-ip:5433/agent_cdss
# SQLAlchemy 格式 (langchain-postgres 用,Step 3 接入)
PG_DSN_SA=postgresql+psycopg://rag:rag123@your-server-ip:5433/agent_cdss
PG_POOL_MIN=2
PG_POOL_MAX=10

# LLM
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding (Step 3 用)
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5 /  text-embedding-v3
# v3 模型的默认维度是 1024
EMBEDDING_DIM=512